package lab3;
import java.util.Scanner;


public class AckerFunction {

    // records how deep the current recursion is (used for indentation)
    private static int spaces = 0;
    private static int numbrofinvocations = 0;
    // counts total number of invocations of acker()
    private static long invocations = 0;

    
    public static int acker(int m, int n) {
        invocations++;

        // indentation for the "Enter" line
        String indentEnter = "    ".repeat(Math.max(0, spaces));
        System.out.println(indentEnter + "Enter method acker: m = " + m + ", n = " + n);

        // increase depth for nested calls
        spaces++;

        int result;
        if (m == 0) {
            result = n + 1;
        } else if (n == 0) {
            result = acker(m - 1, 1);
        } else {
            int temp = acker(m, n - 1);
            result = acker(m - 1, temp);
        }

        // decrease depth, then print leave with matching indentation
        spaces--;
        String indentLeave = "    ".repeat(Math.max(0, spaces));
        System.out.println(indentLeave + "Leave method acker: acker(" + m + ", " + n + ") = " + result);

        return result;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.println("Input two integers separated by a space character (enter \"q\" to quit):");

        while (true) {
            System.out.print("> ");
            String line = scanner.nextLine().trim();

            if (line.equalsIgnoreCase("q")) {
                System.out.println("Quitting.");
                break;
            }

            if (line.isEmpty()) {
                System.out.println("No input detected. Please enter two nonnegative integers or 'q' to quit.");
                continue;
            }

            String[] parts = line.split("\\s+");
            if (parts.length != 2) {
                System.out.println("Invalid input. Please enter exactly two nonnegative integers separated by a space (or 'q' to quit).");
                continue;
            }

            int m, n;
            try {
                m = Integer.parseInt(parts[0]);
                n = Integer.parseInt(parts[1]);
            } catch (NumberFormatException e) {
                System.out.println("Invalid numbers. Make sure both entries are integers >= 0.");
                continue;
            }

            if (m < 0 || n < 0) {
                System.out.println("Please enter nonnegative integers only.");
                continue;
            }

            // Reset tracing counters before each new computation
            spaces = 0;
            invocations = 0;

            try {
                int result = acker(m, n);
                
                System.out.println();
                System.out.println("Total number of invocations = " + invocations + ", result = " + result);
            } catch (StackOverflowError soe) {
                System.out.println();
                System.out.println("Computation failed: recursion depth or call-count exceeded (StackOverflow).");
                System.out.println("Try smaller values for m and/or n (e.g., m <= 3, small n).");
            } catch (OutOfMemoryError oome) {
                System.out.println();
                System.out.println("Computation failed: out of memory. Try much smaller inputs.");
            } catch (Exception ex) {
                System.out.println();
                System.out.println("An unexpected error occurred: " + ex.getMessage());
            }

            
            System.out.println("Enter another pair or 'q' to quit:");
        }

        scanner.close();
    }
}

